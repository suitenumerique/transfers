{
	auto_https off
	admin off
}

:{$PORT} {
	root * {$TRANSFERTS_FRONTEND_ROOT:/app}

	# Security headers on every response Caddy emits (HTML + assets). The
	# Django backend sets its own on /api/* responses; these cover the
	# statically-exported frontend, including the /t/<token> download page.
	header {
		-Server
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		# The download page carries the secret token in its URL path. With
		# same-origin we never send a Referer cross-origin, so the token can't
		# leak to the LaGaufre origins via the Referer header.
		Referrer-Policy "same-origin"
		# Strict CSP: a compromised LaGaufre script update must not be able to
		# exfiltrate a recipient's download token. Only self + the two known
		# suite.anct.gouv.fr origins (widget JS + its services API) are allowed.
		Content-Security-Policy "default-src 'self'; script-src 'self' https://static.suite.anct.gouv.fr; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://static.suite.anct.gouv.fr; font-src 'self' data:; connect-src 'self' https://static.suite.anct.gouv.fr https://operateurs.suite.anct.gouv.fr {$TRANSFERTS_FRONTEND_S3_ORIGIN:https://s3.fr-par.scw.cloud}; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'"
	}

	route {
		# Health checks
		respond /__lbheartbeat__ 200
		respond /__lbheartbeat__/ 200

		# X-Forwarded-For is propagated as-is from Scalingo's edge router so
		# the backend sees the real client IP. Setting {remote_host} here
		# would overwrite it with the internal HAProxy peer (a 10.0.0.x
		# address) and the audit log would lose the user's IP.
		reverse_proxy /__heartbeat__/* {$TRANSFERTS_FRONTEND_BACKEND_SERVER:localhost:8000} {
			header_up X-Forwarded-Proto https
			header_up X-Forwarded-For {http.request.header.x-forwarded-for}
		}

		# Django backend proxy
		reverse_proxy /api/* {$TRANSFERTS_FRONTEND_BACKEND_SERVER:localhost:8000} {
			header_up X-Forwarded-Proto https
			header_up X-Forwarded-For {http.request.header.x-forwarded-for}
		}

		redir /{$DJANGO_ADMIN_URL:admin} /{$DJANGO_ADMIN_URL:admin}/ 301

		reverse_proxy /{$DJANGO_ADMIN_URL:admin}/* {$TRANSFERTS_FRONTEND_BACKEND_SERVER:localhost:8000} {
			header_up X-Forwarded-Proto https
			header_up X-Forwarded-For {http.request.header.x-forwarded-for}
		}

		reverse_proxy /static/* {$TRANSFERTS_FRONTEND_BACKEND_SERVER:localhost:8000} {
			header_up X-Forwarded-Proto https
			header_up X-Forwarded-For {http.request.header.x-forwarded-for}
		}

		# Serve static assets. Missing files fall through to handle_errors
		# below, which applies the SPA fallback for document navigations only.
		file_server
	}

	handle_errors {
		# SPA fallback: serve index.html for missing document navigations so the
		# client-side router (TanStack Router) can resolve the path. Scoped to
		# requests that accept HTML, so missing static assets (JS/CSS chunks)
		# keep their 404 instead of getting a 200 index.html — chunk-load
		# failures and stale-cache issues stay visible.
		@spa_404 expression `{err.status_code} == 404`
		handle @spa_404 {
			@html header Accept *text/html*
			handle @html {
				rewrite * /index.html
				file_server
			}
		}
	}
}
