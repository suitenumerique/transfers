{
	auto_https off
	admin off
}

:{$PORT} {
	root * {$TRANSFERTS_FRONTEND_ROOT:/app}
	header -Server

	route {
		# Health checks
		respond /__lbheartbeat__ 200
		respond /__lbheartbeat__/ 200

		# X-Forwarded-For is propagated as-is from Scalingo's edge router so
		# the backend sees the real client IP. Setting {remote_host} here
		# would overwrite it with the internal HAProxy peer (a 10.0.0.x
		# address) and the audit log would lose the user's IP.
		reverse_proxy /__heartbeat__/* {$TRANSFERTS_FRONTEND_BACKEND_SERVER:localhost:8000} {
			header_up X-Forwarded-Proto https
			header_up X-Forwarded-For {http.request.header.x-forwarded-for}
		}

		# Django backend proxy
		reverse_proxy /api/* {$TRANSFERTS_FRONTEND_BACKEND_SERVER:localhost:8000} {
			header_up X-Forwarded-Proto https
			header_up X-Forwarded-For {http.request.header.x-forwarded-for}
		}

		redir /{$DJANGO_ADMIN_URL:admin} /{$DJANGO_ADMIN_URL:admin}/ 301

		reverse_proxy /{$DJANGO_ADMIN_URL:admin}/* {$TRANSFERTS_FRONTEND_BACKEND_SERVER:localhost:8000} {
			header_up X-Forwarded-Proto https
			header_up X-Forwarded-For {http.request.header.x-forwarded-for}
		}

		reverse_proxy /static/* {$TRANSFERTS_FRONTEND_BACKEND_SERVER:localhost:8000} {
			header_up X-Forwarded-Proto https
			header_up X-Forwarded-For {http.request.header.x-forwarded-for}
		}

		# Serve static assets. Missing files fall through to handle_errors
		# below, which applies the SPA fallback for document navigations only.
		file_server
	}

	handle_errors {
		# SPA fallback: serve index.html for missing document navigations so the
		# client-side router (TanStack Router) can resolve the path. Scoped to
		# requests that accept HTML, so missing static assets (JS/CSS chunks)
		# keep their 404 instead of getting a 200 index.html — chunk-load
		# failures and stale-cache issues stay visible.
		@spa_404 expression `{err.status_code} == 404`
		handle @spa_404 {
			@html header Accept *text/html*
			handle @html {
				rewrite * /index.html
				file_server
			}
		}
	}
}
