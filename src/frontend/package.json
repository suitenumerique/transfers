{
  "name": "transferts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "start": "vite preview",
    "lint": "eslint .",
    "build-theme": "cunningham -g css,scss,ts -o src/styles",

    "test": "vitest run",
    "test:update": "vitest run --update",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "routes:generate": "tsr generate",
    "prebuild": "npm run routes:generate",
    "prets:check": "npm run routes:generate",
    "ts:check": "tsc --noEmit",
    "i18n:extract": "i18next-cli extract",
    "analyze": "ANALYZE=1 vite build && node ./scripts/print-bundle-stats.mjs"
  },
  "dependencies": {
    "@gouvfr-lasuite/cunningham-react": "4.3.0",
    "@gouvfr-lasuite/drive-sdk": "^0.0.2",
    "@gouvfr-lasuite/ui-kit": "0.23.2",
    "@sentry/react": "10.38.0",
    "@tanstack/react-query": "5.90.20",
    "@tanstack/react-query-devtools": "5.91.3",
    "@tanstack/react-router": "1.170.8",
    "@tanstack/react-router-devtools": "1.167.0",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "i18next": "25.7.4",
    "i18next-http-backend": "3.0.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-dropzone": "14.4.0",
    "react-i18next": "16.5.4",
    "react-toastify": "11.0.5",
    "sass": "1.97.3"
  },
  "devDependencies": {
    "@tanstack/eslint-plugin-query": "5.91.4",
    "@tanstack/router-cli": "1.167.13",
    "@tanstack/router-plugin": "1.168.11",
    "@types/node": "25.2.0",
    "@types/react": "19.2.10",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.8",
    "@vitest/ui": "4.1.8",
    "eslint": "9.39.2",
    "eslint-plugin-react-hooks": "7.1.1",
    "i18next-cli": "1.34.1",
    "jsdom": "27.4.0",

    "prettier": "3.8.1",
    "rollup-plugin-visualizer": "7.0.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.60.0",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.57.1",
    "@rollup/rollup-linux-x64-musl": "4.57.1"
  },
  "overrides": {}
}
